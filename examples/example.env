# Comments and blank lines are ignored

APP_NAME=MyService
export APP_ENV=production
PORT=8080
DEBUG=false

# Quoting rules
DB_PASSWORD='p@ss w0rd # not a comment inside single quotes'
GREETING="Hello\nWorld"
TIMEOUT=30 # inline comment after an unquoted value

# Variable expansion
BASE_URL=https://api.example.com
FULL_URL=${BASE_URL}/v1/users
HOME_DIR=$HOME
